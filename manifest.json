{
  "manifest_version": 3,
  "name": "PostMessage Scanner",
  "version": "1.0",
  "description": "Scan loaded JavaScript for postMessage issues",
  "permissions": [
    "debugger",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "devtools_page": "devtools.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}